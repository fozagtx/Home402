# =============================================================
# SolSentinel — Personal Solana DeFi Watchdog
# Nosana x ElizaOS Challenge submission
# =============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# -------------------------------------------------------------
# LLM — Qwen3.5-27B via Nosana hosted inference endpoint
# -------------------------------------------------------------
OPENAI_API_KEY=nosana
OPENAI_API_URL=https://6vq2bcqphcansrs9b88ztxfs88oqy7etah2ugudytv2x.node.k8s.prd.nos.ci/v1
MODEL_NAME=Qwen3.5-27B-AWQ-4bit

# -------------------------------------------------------------
# Embeddings — Qwen3-Embedding-0.6B via Nosana
# -------------------------------------------------------------
OPENAI_EMBEDDING_URL=https://4yiccatpyxx773jtewo5ccwhw1s2hezq5pehndb6fcfq.node.k8s.prd.nos.ci/v1
OPENAI_EMBEDDING_API_KEY=nosana
OPENAI_EMBEDDING_MODEL=Qwen3-Embedding-0.6B
OPENAI_EMBEDDING_DIMENSIONS=1024

# -------------------------------------------------------------
# Optional: Local development with Ollama
# -------------------------------------------------------------
# OPENAI_API_KEY=ollama
# OPENAI_API_URL=http://127.0.0.1:11434/v1
# MODEL_NAME=qwen3.5:27b

# -------------------------------------------------------------
# Solana data sources
# -------------------------------------------------------------
# Free Helius RPC key: https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here
# Wallet to monitor (base58 pubkey)
SOLANA_WALLET=YourWalletPubkeyHere

# -------------------------------------------------------------
# Position source
# -------------------------------------------------------------
# true  → use built-in demo positions (recommended for hackathon demo)
# false → use on-chain Kamino/MarginFi/Drift adapters (post-hackathon)
MOCK_POSITIONS=true

# -------------------------------------------------------------
# Alerting thresholds
# -------------------------------------------------------------
# Warn when any position is within this percent of liquidation
LIQUIDATION_WARN_PCT=15
# UTC hour at which the daily brief is sent
DAILY_BRIEF_HOUR_UTC=7

# -------------------------------------------------------------
# Telegram — user interface
# -------------------------------------------------------------
# Create a bot with @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal chat id (message @userinfobot to get it)
TELEGRAM_CHAT_ID=

# -------------------------------------------------------------
# Server
# -------------------------------------------------------------
NODE_ENV=production
SERVER_PORT=3000
# SQLITE_DATA_DIR=./data
